generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth) ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?

  accounts      Account[]
  sessions      Session[]
  deadlines     Deadline[]
  integrations  Integration[]
  tasks         Task[]
  studySessions StudySession[]
  notifPrefs    NotificationPrefs?
  notifLogs     NotificationLog[]
  pushSubs      PushSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Integration ───────────────────────────────────────────────

model Integration {
  id        String            @id @default(cuid())
  userId    String
  type      IntegrationType
  token     String?           @db.Text
  baseUrl   String?
  status    IntegrationStatus @default(ACTIVE)
  lastSync  DateTime?
  error     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type])
}

enum IntegrationType {
  GOOGLE_CALENDAR
  CANVAS
  GMAIL
  GRADESCOPE
  ED_DISCUSSION
}

enum IntegrationStatus {
  ACTIVE
  ERROR
  DISABLED
}

// ─── Deadline ──────────────────────────────────────────────────

model Deadline {
  id          String         @id @default(cuid())
  userId      String
  title       String
  description String?        @db.Text
  dueAt       DateTime
  source      DeadlineSource
  courseName  String?
  priority    Priority       @default(MEDIUM)
  status      DeadlineStatus @default(PENDING)
  externalId  String?
  url         String?
  suggested   Boolean        @default(false)

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, source, externalId])
  @@index([userId, dueAt])
  @@index([userId, status])
}

enum DeadlineSource {
  GOOGLE_CALENDAR
  CANVAS
  GMAIL
  GRADESCOPE
  ED_DISCUSSION
  MANUAL
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DeadlineStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DISMISSED
}

// ─── Task (subtasks of deadlines) ──────────────────────────────

model Task {
  id              String     @id @default(cuid())
  userId          String
  deadlineId      String?
  title           String
  completed       Boolean    @default(false)
  sortOrder       Int        @default(0)
  estimateMinutes Int?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deadline Deadline? @relation(fields: [deadlineId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deadlineId, sortOrder])
}

// ─── Study Session ─────────────────────────────────────────────

model StudySession {
  id       String   @id @default(cuid())
  userId   String
  title    String
  startAt  DateTime
  endAt    DateTime
  taskId   String?
  notes    String?  @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, startAt])
}

// ─── Notifications ─────────────────────────────────────────────

model NotificationPrefs {
  id              String  @id @default(cuid())
  userId          String  @unique
  emailEnabled    Boolean @default(true)
  pushEnabled     Boolean @default(false)
  smsEnabled      Boolean @default(false)
  dailyDigest     Boolean @default(true)
  reminderHours   Int     @default(24) // hours before deadline
  urgentHours     Int     @default(2)  // hours for urgent reminder

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationLog {
  id         String   @id @default(cuid())
  userId     String
  deadlineId String
  channel    String   // email, sms, push
  type       String   // reminder, urgent, digest
  sentAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deadlineId, channel, type])
}

model PushSubscription {
  id       String @id @default(cuid())
  userId   String
  endpoint String @db.Text
  p256dh   String @db.Text
  auth     String @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
